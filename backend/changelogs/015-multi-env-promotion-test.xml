<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="015-multi-env-promotion-test" author="lalu">
        <comment>Second CI marker to verify DEV, QA, and PROD promotion order</comment>

        <insert tableName="app_settings">
            <column name="setting_key" value="ci_promotion_round2"/>
            <column name="setting_value" value="pending-qa-prod"/>
            <column name="status" value="ACTIVE"/>
        </insert>

        <rollback>
            <delete tableName="app_settings">
                <where>setting_key = 'ci_promotion_round2'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
