<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="016-promotion-smoke-test" author="lalu">
        <comment>Simple marker row for the next DEV to QA to PROD promotion test</comment>

        <insert tableName="app_settings">
            <column name="setting_key" value="promotion_smoke_test"/>
            <column name="setting_value" value="ready"/>
            <column name="status" value="ACTIVE"/>
        </insert>

        <rollback>
            <delete tableName="app_settings">
                <where>setting_key = 'promotion_smoke_test'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
